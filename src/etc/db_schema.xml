<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="inpost_restrictions_rule_product">
        <constraint xsi:type="foreign"
                    referenceId="INPOST_RESTRICTIONS_RULE_PRODUCT_PRODUCT_ID_SEQUENCE_PRODUCT_SEQUENCE_VALUE"
                    table="inpost_restrictions_rule_product"
                    column="product_id"
                    referenceTable="sequence_product"
                    referenceColumn="sequence_value"
                    onDelete="CASCADE"
        />
        <constraint xsi:type="foreign"
                    referenceId="INPOST_RESTRICTIONS_RULE_PRODUCT_PRODUCT_ID_CATALOG_PRODUCT_ENTITY_ENTITY_ID"
                    table="inpost_restrictions_rule_product"
                    column="product_id"
                    referenceTable="catalog_product_entity"
                    referenceColumn="entity_id"
                    onDelete="CASCADE"
                    disabled="1"
        />
	</table>
</schema>
